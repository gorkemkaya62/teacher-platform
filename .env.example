# Bu dosyayı kopyalayıp .env olarak kaydedin ve değerleri doldurun.
# .env dosyası Git'e eklenmez.

SECRET_KEY=your-django-secret-key-here
DEBUG=True

ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# SQLite veritabanı dosyası (proje köküne göre)
SQLITE_DB_NAME=db.sqlite3

# Yüklenen fotoğraflar (ör. /media/images/profil.jpg)
MEDIA_URL=/media/
MEDIA_ROOT=media

SITE_NAME=ogretmenim.com
SITE_TAGLINE=Kurs Merkezleri ve Öğretmen Bulma Platformu

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
